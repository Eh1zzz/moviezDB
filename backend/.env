# MoviezDB Backend — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Port for the Node.js server (default: 3001)
PORT=3001

# Comma-separated list of allowed frontend origins for CORS
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# Optional: absolute path to frontend build directory if serving from backend
# FRONTEND_DIR=/path/to/moviezdb/frontend
